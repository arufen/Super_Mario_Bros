#include "Main.h"
#include "Game.h"
#include "Debug.h"
#include "Camera.h"

Camera MainCamera;

int map_mode;

//---------------------------------------------------------------------------------
//	初期化処理
//---------------------------------------------------------------------------------
void GameInit()
{
		map_mode = MODE_USUALLY;
}

//---------------------------------------------------------------------------------
//	更新処理
//---------------------------------------------------------------------------------
void Debug::Update()
{
	if (PushHitKey(KEY_INPUT_LCONTROL) && CheckHitKey(KEY_INPUT_U))
	{
		map_mode = MODE_USUALLY;
	}

	if( PushHitKey( KEY_INPUT_LCONTROL ) && CheckHitKey( KEY_INPUT_D ) )
	{
		map_mode = MODE_DEBUG;
	}

	if (map_mode == MODE_USUALLY)
	{

	}

	if (map_mode == MODE_DEBUG)
	{

	}
}

//---------------------------------------------------------------------------------
//	描画処理
//---------------------------------------------------------------------------------
void Debug::Render()
{
	// デバッグ情報の表示
	DrawFormatString(0, 0, GetColor(255, 255, 255), "camera pos X : %f, camera pos Y : %f", MainCamera.pos.x, MainCamera.pos.y);

	// 現在のモードを画面の端にでも出しておくとデバッグが捗ります
	if (map_mode == MODE_DEBUG) {
		DrawString(0, 20, "DEBUG MODE ACTIVE", GetColor(255, 0, 0));
	}
}
