#include "Main.h"
#include "Game.h"
#include "Camera.h"
#include "Debug.h"
#include "Map.h"
#include "Mario.h"

extern Camera MainCamera;

//Map マップ
Map MainMap;

Debug MainDebug;

Mario MainMario;

//---------------------------------------------------------------------------------
//	初期化処理
//---------------------------------------------------------------------------------
void GameInit()
{
	//map init
	MainMap.Init();
	// initialize debug subsystem
	MainMario.Init();
	MainDebug.Init();
	MainCamera.pos.Set(0.0f, 0.0f);
}
//---------------------------------------------------------------------------------
//	更新処理
//---------------------------------------------------------------------------------
void GameUpdate()
{
	MainCamera.Update();
	// update debug (handle input for mode switching)
	MainMario.Update();
	MainDebug.Update();
}
//---------------------------------------------------------------------------------
//	描画処理
//---------------------------------------------------------------------------------
void GameRender()
{
    MainMap.Render(MainCamera);
	// draw mario after map so he appears on top
	MainMario.Render();
	MainDebug.Render();
}
//---------------------------------------------------------------------------------
//	終了処理
//---------------------------------------------------------------------------------
void GameExit()
{

}
