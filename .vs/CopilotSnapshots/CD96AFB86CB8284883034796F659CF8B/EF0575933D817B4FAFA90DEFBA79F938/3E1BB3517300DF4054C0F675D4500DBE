#include "Main.h"
#include "Game.h"
#include "Mario.h"
#include "Debug.h"
#include "Camera.h"

extern Camera MainCamera;
// Global speed variable for compatibility with Camera.cpp usage
// Keep this global so Camera.cpp can reference `marioSpeed` without changes.
float marioSpeed = 100.0f;

int mario_centerX;

void Mario::Init()
{
	marioImage.InitialImageAndSize(LoadGraph("data/mario_walk_1.png"));
	marioImage.pos.Set(165.0f, 772.0f);
	isLeft = false;
}
void Mario::Update()
{
	if (CheckHitKey(KEY_INPUT_D))
	{
		marioImage.pos.x += marioSpeed;
		isLeft = false; // 右を向く

		// 【追加】マリオが画面の真ん中（ワールド座標）を越えたら、カメラも同期して右に動かす
		// マリオのワールド中心座標 ＝ マリオの左端 + (幅/2)
		float marioWorldCenterX = marioImage.pos.x + (marioImage.sizeX * 4.0f / 2.0f);

		// 画面の真ん中より右に行こうとしたら
		if (marioWorldCenterX >= MainCamera.pos.x + (SCREEN_W / 2))
		{
			// カメラの座標を、マリオがちょうど真ん中に乗る位置に強制固定する
			MainCamera.pos.x = marioWorldCenterX - (SCREEN_W / 2);
		}
	}
	// Aキーで左に移動（テスト用に、もし左移動も入れるなら）
	if (CheckHitKey(KEY_INPUT_A))
	{
		marioImage.pos.x -= marioSpeed;
		isLeft = true;  // 左を向く
	}

	// 【カメラの限界値を考慮したマリオの左端ブロック】
	// 先にカメラの限界チェック（0〜12480）をCamera::Update等で行うか、ここで行う必要があります
	if (MainCamera.pos.x < 0) MainCamera.pos.x = 0;
	if (MainCamera.pos.x > 12480) MainCamera.pos.x = 12480;

	// 【左端制限】マリオがカメラの左端より左に行かないようにする
	if (marioImage.pos.x < MainCamera.pos.x)
	{
		marioImage.pos.x = MainCamera.pos.x;
	}

	// 【右端制限】マリオがステージの右端（12480 + 画面ハバ）より先に行かないようにする
	// マリオの右端のワールド座標 ＝ マリオの左端 ＋ 実際の表示幅
	float marioWidth = marioImage.sizeX * 4.0f;
	float marioRightX = marioImage.pos.x + marioWidth;

	// ステージ全体の右端（カメラの限界12480 ＋ 画面の横幅）
	float stageRightLimit = 12480.0f + SCREEN_W;

	if (marioRightX > stageRightLimit)
	{
		// 右端を越えていたら、ステージ右端にピッタリくっつく位置に戻す
		marioImage.pos.x = stageRightLimit - marioWidth;
	}

	int screenX = (int)(marioImage.pos.x - MainCamera.pos.x);
	mario_centerX = screenX + (marioWidth / 2);
}

void Mario::Render()
{
	// マリオの画像を描画する
	// ※もし marioImage.Render() や marioImage.Draw() のような関数があれば、そちらを呼んでください。
    // Draw at screen position relative to camera (camera.pos is top-left world coord)
	int screenX = (int)(marioImage.pos.x - MainCamera.pos.x);
	int screenY = (int)(marioImage.pos.y - MainCamera.pos.y);
    // Draw scaled 4x using top-left as origin
	if (isLeft)
	{
		DrawRotaGraph2(screenX, screenY, 0, 0, 4.0f, 0.0, marioImage.image, TRUE, TRUE);
	}
	else
	{
		DrawRotaGraph2(screenX, screenY, 0, 0, 4.0f, 0.0, marioImage.image, TRUE, FALSE);
	}

	// 2. デバッグモードなら、その上に当たり判定の枠線を重ねて描画する
	if (map_mode == MODE_DEBUG)
	{
		// DxLibの座標指定は int型 なので、float から int にキャスト（変換）しておくと安全です
        int x1 = screenX;
		int y1 = screenY;
        int x2 = x1 + (int)(marioImage.sizeX * 4.0f);
		int y2 = y1 + (int)(marioImage.sizeY * 4.0f);

      // 緑の枠線を描画（FALSE で塗りつぶしなし）
		DrawBox(x1, y1, x2, y2, GetColor(0, 255, 0), FALSE);

		// マリオ画像の X 真ん中に縦ラインを引く（画像部分のみ）
		int mario_centerX = x1 + ((x2 - x1) / 2);
		// ラインを画像の上端から下端まで描画
		DrawLine(mario_centerX, y1, mario_centerX, y2, GetColor(0, 255, 0));
	}
}