#include "Main.h"
#include "Camera.h"
#include "Mario.h"
#include "Game.h" // SCREEN_W があるファイル

extern Camera MainCamera;

//Constructor
Camera::Camera() 
{
	pos = { 0.0f, 0.0f };
}

void Camera::SetPos(Float2 targetPos)
{
	pos.Set(targetPos);
}

void Camera::GlobalRenderImage(const Image& image, float scale)
{
	Float2 globalPos;
	globalPos.Set(image.pos.x - pos.x, image.pos.y - pos.y);
	image.Render(globalPos, scale);
}

void Camera::Update()
{
	if (CheckHitKey(KEY_INPUT_D)) { pos.x += marioSpeed; }
//	if (CheckHitKey(KEY_INPUT_A)) { pos.x -= marioSpeed; }
//	if (CheckHitKey(KEY_INPUT_W)) { pos.y -= marioSpeed; }
//	if (CheckHitKey(KEY_INPUT_S)) { pos.y += marioSpeed; }
	if( MainCamera.pos.x <= 0){
		MainCamera.pos.x = 0;
	}

	Float2 mpos = MainMario.GetCenterPosition();
	// Only move camera to the right to follow Mario; do not move left when Mario moves left.
	float desiredX = mpos.x - (SCREEN_W / 2);
	if (desiredX > pos.x) {
		pos.x = desiredX;
	}

	// If Mario's vertical center on screen is at or below the screen middle,
	// move the camera down by marioSpeed so the camera follows Mario downward.
	float marioScreenY = mpos.y - pos.y; // Mario center in screen coordinates
	if (marioScreenY >= (SCREEN_H / 2)) {
		pos.y += marioSpeed;
	}

	if (pos.x < 0.0f) pos.x = 0.0f;
	if (pos.y < 0.0f) pos.y = 0.0f;
}