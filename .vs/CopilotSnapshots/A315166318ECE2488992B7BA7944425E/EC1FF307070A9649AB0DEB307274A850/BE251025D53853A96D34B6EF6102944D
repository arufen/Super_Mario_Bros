#include "Main.h"
#include "Camera.h"
#include "Mario.h"
#include "Game.h" // SCREEN_W があるファイル

extern Camera MainCamera;
extern Mario MainMario;

//Constructor
Camera::Camera() 
{
	pos = { 0.0f, 0.0f };
}

void Camera::SetPos(Float2 targetPos)
{
	pos.Set(targetPos);
}

void Camera::GlobalRenderImage(const Image& image, float scale)
{
	Float2 globalPos;
	globalPos.Set(image.pos.x - pos.x, image.pos.y - pos.y);
	image.Render(globalPos, scale);
}

void Camera::Update()
{
  Float2 mpos = MainMario.GetPosition();
	// Only move camera to the right to follow Mario; do not move left when Mario moves left.
	float desiredX = mpos.x - (SCREEN_W / 2);
	if (desiredX > pos.x) {
		pos.x = desiredX;
	}

	if (pos.x < 0.0f) pos.x = 0.0f;
	if (pos.y < 0.0f) pos.y = 0.0f;
}