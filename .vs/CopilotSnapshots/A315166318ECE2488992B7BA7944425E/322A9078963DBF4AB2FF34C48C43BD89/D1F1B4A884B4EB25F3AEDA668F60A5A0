#define PI 3.141592653589793

float Lerp(float a, float b, float t) //smooth animation
{
    return a + t * (b - a);
}

float GetAngle(float x1, float y1, float x2, float y2)
{
	return atan2f(y2 - y1, x2 - x1) * 180.0f / PI;
}


float ToRadius(float angle)
{
	return angle * (PI / 180.0f);
}

//Move towards a point
void MoveTowards(float& x, float& y, float rot, float speed)
{

	x += cosf(ToRadius(rot)) * speed;
	y += sinf(ToRadius(rot)) * speed;
}

bool HitDetectBox(float x1, float y1, float x2, float y2, Image sprite1, Image sprite2)
{

	float xW1 = (float)sprite1.sizeX; //width
	float yH1 = (float)sprite1.sizeY; //height
	float adjustedX1 = x1 - (xW1 / 2);
	float adjustedY1 = y1 - (yH1 / 2);

	float xW2 = (float)sprite2.sizeX; //width
	float yH2 = (float)sprite2.sizeY; //height
	float adjustedX2 = x2 - (xW2 / 2);
	float adjustedY2 = y2 - (yH2 / 2);

	if (
		(adjustedX2 + xW2 >= adjustedX1) //hit to the right
		&&
		(adjustedX1 + xW1 >= adjustedX2) //hit to the left
		&&
		(adjustedY1 + yH1 >= adjustedY2) //hit to bottom
		&&
		(adjustedY2 + yH2 >= adjustedY1) //hit to top
		)
	{
		return true;
	}

	return false;
}

void Animation::InitialAnimation(int image, int frameCount, int FPS)
{
	this->sprite.InitialImageAndSize(image);
	this->frameCount = frameCount;
	this->FPS = FPS;
	animationSpeed = FPS;
	sprite.sizeX /= frameCount;
}

void Animation::AnimationUpdateLoop()
{
	animationSpeed--;
	if (animationSpeed <= 0)
	{
		currentFrame++;
		animationSpeed = 60 / FPS;
	}
	
	if (currentFrame >= frameCount) currentFrame = 0;
}

void Animation::AnimationUpdateOnce()
{
	// Don't update if animation is completed
	if (state != AnimationState::PLAYING) {
		currentFrame = frameCount - 1;
		return;
	}

	animationSpeed--;
	if (animationSpeed <= 0)
	{
		currentFrame++;
		animationSpeed = 60 / FPS;

		// Check if animation reached the end
		if (currentFrame >= frameCount)
		{
			currentFrame = frameCount - 1; // Stay on last frame
			state = AnimationState::COMPLETED; // Mark as completed
		}
	}
}

void Animation::PlayAnimation()
{
	state = AnimationState::PLAYING;
	currentFrame = 0;
}

void Animation::AnimationRender(const float x, const float y)
{
	int currentImage = currentFrame * (sprite.sizeX);
	float sizeX = (float)sprite.sizeX;
	float sizeY = (float)sprite.sizeY;
	int image = sprite.image;
	DrawRectGraphF(x, y, currentImage, 0, sizeX, sizeY, image, true);
}

void Animation::AnimationRenderCenter(bool reverseFlag)
{
	float x = this->x;
	float y = this->y;
	int currentImage = currentFrame * (sprite.sizeX);
	float sizeX = (float)sprite.sizeX;
	float sizeY = (float)sprite.sizeY;
	int image = sprite.image;
	DrawRectGraphF(x - (sizeX / 2), y - (sizeY / 2), currentImage, 0, sizeX, sizeY, image, true, reverseFlag);
}

//TIMER
void Timer::Update()
{
	if(currentFrame > 0) currentFrame--;
	
}

bool Timer::TimerHit()
{
	if (currentFrame <= 0)
	{
		return true;
	}
	return false;
}

void Timer::ResetTimer()
{
	currentFrame = MAX_TIMER * 60;
}

void Timer::SetTimer(float seconds)
{
	currentFrame = seconds * 60;
}

bool Timer::HitAndReset()
{
	if (TimerHit())
	{
		ResetTimer();
		return true;
	}
	return false;
}

float Timer::GetCurrentTimer()
{
	float currentTime;
	currentTime = currentFrame / 60.0f;

	return currentTime;
}

