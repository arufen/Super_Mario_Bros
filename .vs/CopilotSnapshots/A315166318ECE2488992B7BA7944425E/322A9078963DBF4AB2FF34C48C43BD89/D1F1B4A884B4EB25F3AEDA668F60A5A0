float easeOutBounceFunc(float t) {
	const float n1 = 7.5625f;
	const float d1 = 2.75f;

	if (t < 1.0f / d1) {
		return n1 * t * t;
	}
	else if (t < 2.0f / d1) {
		t -= 1.5f / d1;
		return n1 * t * t + 0.75f;
	}
	else if (t < 2.5f / d1) {
		t -= 2.25f / d1;
		return n1 * t * t + 0.9375f;
	}
	else {
		t -= 2.625f / d1;
		return n1 * t * t + 0.984375f;
	}
}

void easeOutBounce(
	float& x,
	float fromX,
	float toX,
	float& frameTime,
	float durationSeconds,
	float fps
) {
	// Increase frame counter
	frameTime += 1.0f;        // 1 frame per update

	// Convert sec→frames
	float totalFrames = durationSeconds * fps;

	// Normalized 0→1
	float t = frameTime / totalFrames;
	if (t > 1.0f) t = 1.0f;

	// easing
	float e = easeOutBounceFunc(t);

	// lerp
	x = fromX + (toX - fromX) * e;
}


