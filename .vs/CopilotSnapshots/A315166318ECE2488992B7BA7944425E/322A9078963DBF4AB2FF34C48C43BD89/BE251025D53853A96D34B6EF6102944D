#include"Main.h"
#include "Camera.h";

//Constructor
Camera::Camera() 
{
	pos = { 0.0f, 0.0f };
}

void Camera::SetPos(Float2 targetPos)
{
	pos.Set(targetPos);
}

void Camera::GlobalRenderImage(const Image& image)
{
	Float2 globalPos;
	globalPos.Set(image.pos.x - pos.x, image.pos.y - pos.y);
	image.RenderCenter(globalPos);
}

void Camera::Update()
{
	float cameraSpeed = 2.0f;
	if (CheckHitKey(KEY_INPUT_RIGHT)) { pos.x += cameraSpeed; }
	if (CheckHitKey(KEY_INPUT_LEFT)) { pos.x -= cameraSpeed; }
	if (CheckHitKey(KEY_INPUT_UP)) { pos.y -= cameraSpeed; }
	if (CheckHitKey(KEY_INPUT_DOWN)) { pos.y += cameraSpeed; }
}